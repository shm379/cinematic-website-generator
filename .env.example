# Cinemate — environment variables (all optional)
# Copy to .env for local dev, or set these in Coolify's environment settings.

# Port the server binds to (Coolify/Docker set this; defaults to 3000).
# PORT=3000

# Card images — POST /api/image — and the /gallery search.
# Primary source: Pexels stock photos THROUGH NabuGate's photo proxy: when
# NABU_BASE_URL is set (see below), photos are fetched from
# {NABU_BASE_URL}/v1/photos/search with the NabuGate key — the Pexels key lives
# only inside the gateway (PEXELS_API_KEY on the NabuGate deployment).
#
# Legacy/local mode: talk to Pexels directly with your own key (free at
# https://www.pexels.com/api/). Used only when NABU_BASE_URL is unset.
# PEXELS_API_KEY=...
#
# Optional fallback: OpenAI gpt-image generation. Used only when no stock
# source is configured, or when a stock search fails. Without any key, the
# buttons return a friendly "configure a key" message.
# OPENAI_API_KEY=sk-...
# OPENAI_IMAGE_MODEL=gpt-image-1

# Mega-prompt → site — POST /api/generate-from-prompt.
# Resolution order: NabuGate → Anthropic → keyless heuristic (always works).

# NabuGate — the org's OpenAI-compatible AI gateway. Preferred: set this and the
# project routes its AI through the gateway instead of calling a provider directly.
# NABU_BASE_URL=https://nabugate.internal      # gateway root (no trailing /v1)
# NABU_API_KEY=nabu_...                         # a NabuGate project key
# NABU_MODEL=nabu-smart                         # any NabuGate alias or agent
#   Tip: NABU_MODEL can also be a cinematic sub-agent, e.g. cine-content-strategist.

# Anthropic (used only when NABU_BASE_URL is unset). Without any key, a keyless
# heuristic parser is used instead.
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8
